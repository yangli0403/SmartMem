# 数据库连接信息
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=smartmem

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key

# 记忆检索策略: simple (默认, SQL LIKE) 或 hybrid (向量+BM25)
MEMORY_RETRIEVAL_STRATEGY=simple

# Reflect 综合推理开关: true 启用, false 关闭 (默认)
# 仅在 MEMORY_RETRIEVAL_STRATEGY=hybrid 时生效
# 启用后会增加约 0.5-1.5 秒的额外延迟（LLM 调用）
MEMORY_REFLECT_ENABLED=false
